# ByteBay — déploiement NAS
# Copier vers .env et adapter

BYTEBAY_WEB_PORT=8080
BYTEBAY_SECRET_KEY=change-me-in-production
BYTEBAY_ADMIN_USER=admin
BYTEBAY_ADMIN_PASSWORD=change-me

# Chemins hôte
BYTEBAY_DATA_PATH=/srv/bytebay
BYTEBAY_VOLUMES_PATH=/srv/bytebay-volumes

# Sockets (dans Docker : montés sous /var/bytebay/sockets, pas /run — tmpfs)
# BYTEBAY_AGENT_SOCKET=/var/bytebay/sockets/agent.sock
# BYTEBAY_ENGINE_SOCKET=/var/bytebay/sockets/engine.sock

# Tokens optionnels (même valeur côté agent/engine si activés)
BYTEBAY_AGENT_TOKEN=
BYTEBAY_ENGINE_TOKEN=

# GID groupe bytebay (rempli par deploy/install.sh)
BYTEBAY_GID=

# Ports partages (engine en network_mode: host — ports standards sur le NAS)
BYTEBAY_SAMBA_PORT=445
BYTEBAY_NFS_PORT=2049
BYTEBAY_FTP_PORT=21
